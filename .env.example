# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# Generate a strong SECRET_KEY at: https://djecrety.ir/

# ── Core ─────────────────────────────────────────────────────────────────────

SECRET_KEY=your-very-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ── Session & CSRF Cookies ────────────────────────────────────────────────────
# Set to False during local development (no HTTPS).
# Set to True in production (requires HTTPS).

SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ── HTTPS / HSTS ──────────────────────────────────────────────────────────────
# Set SECURE_SSL_REDIRECT=True and SECURE_HSTS_SECONDS=31536000 in production.

SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0

# ── Production example (uncomment and update when deploying) ──────────────────
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
